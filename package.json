{
  "name": "mailyou",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "dist/electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "MAILYOU_TARGET=web vite",
    "typecheck": "vue-tsc --noEmit",
    "build": "npm run typecheck && npm run build:rust && vite build && npm run copy:rust-binary",
    "build:web": "npm run typecheck && MAILYOU_TARGET=web vite build",
    "build:rust": "cargo build --release --manifest-path src/rust/Cargo.toml",
    "check:rust": "cargo check --manifest-path src/rust/Cargo.toml",
    "copy:rust-binary": "node scripts/copy-rust-binary.mjs",
    "preview": "vite preview",
    "dist": "npm run build && electron-builder --linux",
    "dist:appimage": "npm run build && electron-builder --linux AppImage",
    "dist:deb": "npm run build && electron-builder --linux deb",
    "dist:rpm": "npm run build && electron-builder --linux rpm",
    "dist:zip": "npm run build && electron-builder --linux zip"
  },
  "author": "MailYou Devs",
  "description": "Desktop email client",
  "dependencies": {
    "@mdi/font": "^7.4.47",
    "@mdi/js": "^7.4.47",
    "dompurify": "^3.3.3",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3",
    "vuetify": "^4.0.2"
  },
  "devDependencies": {
    "@types/dompurify": "^3.0.5",
    "@types/node": "^25.4.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "^3.2.5"
  }
}
